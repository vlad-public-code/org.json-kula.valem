{
  "_name": "Customer Satisfaction Survey",
  "_description": "Conditional follow-up questions: issue details appear only when issues are reported, contact fields only for low ratings. Uses metaDerivations to control field visibility (x-valem-relevant) and mutability (readOnly).",
  "id": "customer-satisfaction-survey",
  "version": "1.0.0",
  "schema": {
    "type": "object",
    "properties": {
      "overallRating": {
        "type": "integer",
        "minimum": 1,
        "maximum": 5,
        "description": "Overall satisfaction score 1 (very dissatisfied) – 5 (very satisfied)"
      },
      "wouldRecommend": {
        "type": "boolean",
        "description": "Would the respondent recommend the product/service?"
      },
      "issueEncountered": {
        "type": "boolean",
        "description": "Did the respondent encounter any issues?"
      },
      "issueCategory": {
        "type": [
          "string",
          "null"
        ],
        "enum": [
          "product",
          "service",
          "shipping",
          "billing",
          "other",
          null
        ],
        "description": "Category of the issue (relevant only when issueEncountered = true)"
      },
      "issueDetails": {
        "type": [
          "string",
          "null"
        ],
        "description": "Free-text description of the issue (relevant only when issueEncountered = true)"
      },
      "contactPermission": {
        "type": [
          "boolean",
          "null"
        ],
        "description": "May we contact you? (relevant only when issueEncountered = true AND overallRating ≤ 3)"
      },
      "contactEmail": {
        "type": [
          "string",
          "null"
        ],
        "description": "Contact email (relevant only when contactPermission = true)"
      },
      "sentimentScore": {
        "type": "integer",
        "readOnly": true,
        "description": "0–100 composite sentiment score"
      },
      "priorityFlag": {
        "type": "boolean",
        "readOnly": true,
        "description": "True when immediate follow-up is required"
      }
    },
    "required": [
      "overallRating"
    ]
  },
  "derivations": [
    {
      "path": "$.sentimentScore",
      "expr": "$max([0, $min([100, overallRating * 16 + (wouldRecommend = true ? 20 : 0) - (issueEncountered = true ? 20 : 0)])])"
    },
    {
      "path": "$.priorityFlag",
      "expr": "overallRating <= 2 and issueEncountered = true"
    }
  ],
  "metaDerivations": [
    {
      "path": "$.issueCategory",
      "property": "relevant",
      "expr": "issueEncountered = true"
    },
    {
      "path": "$.issueDetails",
      "property": "relevant",
      "expr": "issueEncountered = true"
    },
    {
      "path": "$.contactPermission",
      "property": "relevant",
      "expr": "issueEncountered = true and overallRating <= 3"
    },
    {
      "path": "$.contactEmail",
      "property": "relevant",
      "expr": "contactPermission = true"
    },
    {
      "path": "$.issueCategory",
      "property": "readOnly",
      "expr": "issueEncountered != true"
    },
    {
      "path": "$.issueDetails",
      "property": "readOnly",
      "expr": "issueEncountered != true"
    },
    {
      "path": "$.contactPermission",
      "property": "readOnly",
      "expr": "issueEncountered != true or overallRating > 3"
    },
    {
      "path": "$.contactEmail",
      "property": "readOnly",
      "expr": "contactPermission != true"
    }
  ],
  "constraints": [
    {
      "id": "rating-in-range",
      "expr": "overallRating >= 1 and overallRating <= 5",
      "message": "Rating must be between 1 and 5",
      "policy": "rollback"
    }
  ],
  "actions": [],
  "defaultValues": [
    {
      "path": "$",
      "expr": "{\"overallRating\": 5, \"wouldRecommend\": true, \"issueEncountered\": false}"
    }
  ],
  "viewDefinition": {
    "renderer": "builtin",
    "defaultView": "main",
    "views": [
      {
        "id": "main",
        "label": "Survey",
        "layout": "vertical",
        "components": [
          {
            "id": "ratingField",
            "type": "radioField",
            "label": "Overall Satisfaction",
            "bind": "$.overallRating",
            "options": [
              {
                "value": "1",
                "label": "1 — Very dissatisfied"
              },
              {
                "value": "2",
                "label": "2 — Dissatisfied"
              },
              {
                "value": "3",
                "label": "3 — Neutral"
              },
              {
                "value": "4",
                "label": "4 — Satisfied"
              },
              {
                "value": "5",
                "label": "5 — Very satisfied"
              }
            ]
          },
          {
            "id": "recommendField",
            "type": "checkboxField",
            "label": "I would recommend this product/service",
            "bind": "$.wouldRecommend"
          },
          {
            "id": "issueField",
            "type": "checkboxField",
            "label": "I encountered an issue",
            "bind": "$.issueEncountered"
          },
          {
            "id": "issueCategoryField",
            "type": "selectField",
            "label": "Issue Category",
            "bind": "$.issueCategory",
            "options": [
              {
                "value": "product",
                "label": "Product"
              },
              {
                "value": "service",
                "label": "Service"
              },
              {
                "value": "shipping",
                "label": "Shipping"
              },
              {
                "value": "billing",
                "label": "Billing"
              },
              {
                "value": "other",
                "label": "Other"
              }
            ]
          },
          {
            "id": "issueDetailsField",
            "type": "textAreaField",
            "label": "Issue Details",
            "bind": "$.issueDetails",
            "placeholder": "Describe the issue...",
            "rows": 4
          },
          {
            "id": "contactPermissionField",
            "type": "checkboxField",
            "label": "You may contact me about this issue",
            "bind": "$.contactPermission"
          },
          {
            "id": "contactEmailField",
            "type": "emailField",
            "label": "Contact Email",
            "bind": "$.contactEmail",
            "placeholder": "your@email.com"
          },
          {
            "id": "sep1",
            "type": "separatorLine"
          },
          {
            "id": "sentimentGroup",
            "type": "group",
            "layout": "horizontal",
            "components": [
              {
                "id": "sentimentLabel",
                "type": "label",
                "label": "Sentiment Score",
                "bind": "$.sentimentScore"
              },
              {
                "id": "priorityBadge",
                "type": "badge",
                "label": "Priority",
                "bind": "$.priorityFlag",
                "text": "priorityFlag = true ? 'Needs follow-up' : 'Normal'",
                "variant": "priorityFlag = true ? 'danger' : 'secondary'"
              }
            ]
          }
        ]
      }
    ]
  },
  "tests": [
    {
      "description": "satisfied respondent — high score, no priority flag",
      "given": {
        "$.overallRating": 5,
        "$.wouldRecommend": true,
        "$.issueEncountered": false
      },
      "expect": {
        "$.sentimentScore": 100,
        "$.priorityFlag": false
      }
    },
    {
      "description": "issue reported with mid rating — medium score, no priority",
      "given": {
        "$.overallRating": 3,
        "$.wouldRecommend": false,
        "$.issueEncountered": true
      },
      "expect": {
        "$.sentimentScore": 28,
        "$.priorityFlag": false
      }
    },
    {
      "description": "low rating with issue and contact permission — low score, priority flagged",
      "given": {
        "$.overallRating": 2,
        "$.wouldRecommend": false,
        "$.issueEncountered": true,
        "$.issueCategory": "service",
        "$.contactPermission": true
      },
      "expect": {
        "$.sentimentScore": 12,
        "$.priorityFlag": true
      }
    }
  ]
}
